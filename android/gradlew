#!/bin/sh

#
# Gradle wrapper script — self-contained, no gradle-wrapper.jar required.
# Reads gradle-wrapper.properties, downloads Gradle if needed, then runs it.
#

set -e

# Resolve APP_HOME (directory containing this script)
PRG="$0"
while [ -h "$PRG" ]; do
    ls=$( ls -ld -- "$PRG" )
    link=${ls#*' -> '}
    case $link in
        /*) PRG=$link ;;
        *)  PRG=$( dirname "$PRG" )/$link ;;
    esac
done
APP_HOME=$( cd "$( dirname "$PRG" )" > /dev/null && pwd -P ) || exit 1
APP_NAME=${0##*/}

# --- 1. Read wrapper properties ---
PROPS="$APP_HOME/gradle/wrapper/gradle-wrapper.properties"
if [ ! -f "$PROPS" ]; then
    echo "ERROR: $PROPS not found" >&2
    exit 1
fi

# Parse distribution URL from properties
DIST_URL=$( grep "^distributionUrl" "$PROPS" | head -1 | sed 's/.*=//' | tr -d '[:space:]' )
if [ -z "$DIST_URL" ]; then
    echo "ERROR: distributionUrl not found in $PROPS" >&2
    exit 1
fi

# Extract version from URL for the cache path
DIST_VERSION=$( echo "$DIST_URL" | sed 's/.*gradle-//' | sed 's/-bin\.zip//' )
DIST_NAME="gradle-$DIST_VERSION"

# --- 2. Determine Java command ---
if [ -n "$JAVA_HOME" ]; then
    if [ -x "$JAVA_HOME/jre/sh/java" ]; then
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ]; then
        echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME" >&2
        exit 1
    fi
else
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1; then
        echo "ERROR: JAVA_HOME is not set and no 'java' command found in PATH" >&2
        exit 1
    fi
fi

# --- 3. Locate or download Gradle ---
GRADLE_USER_HOME=${GRADLE_USER_HOME:-$HOME/.gradle}
DIST_DIR="$GRADLE_USER_HOME/wrapper/dists/$DIST_NAME"

# Build a unique hash from the URL for the subdirectory
URL_HASH=$( echo "$DIST_URL" | md5sum 2>/dev/null | cut -d' ' -f1 || echo "default" )
GRADLE_DIR="$DIST_DIR/$URL_HASH"

if [ ! -d "$GRADLE_DIR/$DIST_NAME" ]; then
    echo "Downloading Gradle $DIST_VERSION..."
    mkdir -p "$DIST_DIR"
    ZIP_FILE="$DIST_DIR/gradle-$DIST_VERSION-bin.zip"

    if [ ! -f "$ZIP_FILE" ]; then
        # Try curl, then wget, then python
        if command -v curl >/dev/null 2>&1; then
            curl -sS -L --retry 3 -o "$ZIP_FILE" "$DIST_URL"
        elif command -v wget >/dev/null 2>&1; then
            wget -q --show-progress -O "$ZIP_FILE" "$DIST_URL"
        elif command -v python3 >/dev/null 2>&1; then
            python3 -c "
import urllib.request, sys
url = '$DIST_URL'
print(f'Downloading {url}...')
urllib.request.urlretrieve(url, '$ZIP_FILE')
" || python -c "
import urllib.request, sys
url = '$DIST_URL'
print(f'Downloading {url}...')
urllib.request.urlretrieve(url, '$ZIP_FILE')
"
        else
            echo "ERROR: No download tool found (curl, wget, python)" >&2
            exit 1
        fi
    fi

    echo "Extracting..."
    unzip -q -o "$ZIP_FILE" -d "$GRADLE_DIR"
    # Mark that extraction is done
    touch "$GRADLE_DIR/.extracted"
fi

# Find the actual Gradle binary
GRADLE_BIN="$GRADLE_DIR/$DIST_NAME/bin/gradle"
if [ ! -f "$GRADLE_BIN" ]; then
    # Try without versioned subdirectory
    GRADLE_BIN="$GRADLE_DIR/bin/gradle"
fi
if [ ! -f "$GRADLE_BIN" ]; then
    echo "ERROR: Gradle binary not found in $GRADLE_DIR" >&2
    ls -la "$GRADLE_DIR/" >&2
    exit 1
fi

# --- 4. Run Gradle ---
exec "$GRADLE_BIN" "$@"
