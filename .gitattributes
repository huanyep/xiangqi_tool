# Gradle wrapper — must use LF line endings for Linux CI
gradlew text eol=lf
gradlew.bat text eol=crlf

# Android project
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.bat text eol=crlf

# Binaries
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
